GROQ_API_KEY=

# S3-совместимое хранилище (опционально) — прямая загрузка больших файлов в обход
# лимитов Render-прокси на размер/длительность запроса. Если не заполнено,
# используется старая загрузка через сервер (подходит для небольших файлов /
# локальной разработки). По умолчанию endpoint/регион настроены на Yandex Object
# Storage — для другого S3-совместимого провайдера переопредели S3_ENDPOINT_URL
# и S3_REGION.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# S3_ENDPOINT_URL=https://storage.yandexcloud.net
# S3_REGION=ru-central1
